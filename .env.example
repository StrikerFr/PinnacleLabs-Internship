# =============================================================================
# WeatherWatch AI — Environment Variables
# =============================================================================
# Copy this file to `.env` for local development, or add these variables in
# Vercel: Project Settings → Environment Variables.
#
# Two flavors:
#   - VITE_*          → exposed to the browser at build time. NEVER put secrets here.
#   - everything else → server-only (read via process.env inside server functions).
# =============================================================================

# -------- Server-only secrets (required) --------

# Groq API key — powers the AI weather narration (src/lib/weather.functions.ts).
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here


# -------- Optional / future use --------

# NODE_ENV is set automatically by Vercel; only override locally if needed.
# NODE_ENV=development

# Examples for future integrations (uncomment if/when you add them):
# DATABASE_URL=postgres://user:pass@host:5432/db
# STRIPE_SECRET_KEY=sk_live_xxx


# -------- Public (browser-exposed) config --------
# Anything prefixed VITE_ is bundled into the client. Use ONLY for non-secret values.
# VITE_PUBLIC_SITE_URL=https://your-domain.com
