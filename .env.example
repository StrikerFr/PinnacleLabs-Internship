# -----------------------------------------------------------------------------
# VedaGlows E-Commerce Project Environment Configuration Template (.env.example)
#
# Copy this file to '.env.local' or '.env' and populate with your own values.
# Do NOT commit actual secrets or keys to the git repository.
# -----------------------------------------------------------------------------

# Application Environment Configuration
NODE_ENV=development
NITRO_PRESET=vercel

# Supabase Local/Production Integration Settings
# Note: The project runs a mock client by default, but these are required for a real database connection.
VITE_SUPABASE_URL=https://your-supabase-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-private-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-supabase-project-id.supabase.co:5432/postgres

# Razorpay Payment Gateway Configuration
# Required for online checkout transaction processing (INR)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Store General Settings Overrides
VITE_STORE_URL=http://localhost:3000
VITE_SUPPORT_EMAIL=vedaglows@gmail.com
